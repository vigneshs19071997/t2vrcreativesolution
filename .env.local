# ============================================
# T2VR Creative Solution — Environment Variables
# ============================================
# Copy this file as .env.local and fill in your values
# NEVER commit .env.local to version control!

# ── MongoDB Connection ──────────────────────
# Get free cluster at: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
# MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/t2vr_enquiries
MONGODB_URI=mongodb://localhost:27017/test-t2vr
# ── Email Configuration (Gmail) ─────────────
# Step 1: Enable 2-Factor Authentication on Gmail
# Step 2: Go to Google Account → Security → App Passwords
# Step 3: Generate App Password for "Mail" and paste below
EMAIL_USER=vigneshs19071997@gmail.com
EMAIL_PASS=yiglraabrtdemdtp

# ── Admin Notification Email ─────────────────
# Email address where you want to receive enquiry notifications
# Can be same as EMAIL_USER
ADMIN_EMAIL=t2vrcreation@gmail.com

# ── Next.js (optional) ──────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
